# --- Browser (Vite) — safe to expose, shipped in the client bundle ---
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Server-only (scripts/generate.js + GitHub Actions) ---
# NEVER prefix these with VITE_ and never import them from src/ — they must
# not reach the browser. In CI these live as GitHub Secrets, not in this file.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
STORAGE_BUCKET=resources
MAX_CHAPTERS_PER_RUN=3
# Optional: comma-separated chapter UUIDs to target. Leave blank for auto
# gap-fill (only chapters with no test yet).
TARGET_CHAPTER_IDS=

# Email summary after each run (optional — omit to skip email)
RESEND_API_KEY=your_resend_api_key_here
REVIEW_NOTIFY_EMAIL=you@example.com
REVIEW_FROM_EMAIL=onboarding@resend.dev
SITE_URL=https://psycho12e4.github.io/TOPPRIUM/
